---
import { socialList, SITE } from '@lib/seo';
const year = new Date().getFullYear();
---

<footer
  id="footer"
  data-index="7"
  class="relative overflow-hidden border-t border-line/40 pt-24 pb-10"
>
  <div class="container-page">
    <div class="flex items-end justify-between mb-12 gap-6 flex-wrap">
      <div class="font-mono text-[11px] tracking-[0.3em] uppercase text-muted">
        07 · END OF LINE
      </div>
      <a
        href="#hero"
        class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-muted hover:text-lime"
        data-cursor-label="top"
      >
        ↑ back to top
      </a>
    </div>

    {/* Massive V9DEV lockup */}
    <div
      aria-hidden
      class="font-display font-black leading-[0.85] tracking-tighter select-none mb-12"
      style="font-size: clamp(5rem, 28vw, 24rem); -webkit-text-stroke: 1.5px var(--color-text); color: transparent;"
    >
      V9DEV
    </div>

    <div class="grid md:grid-cols-3 gap-8 pt-8 border-t border-line/40">
      <div>
        <p class="font-mono text-xs text-muted uppercase tracking-widest mb-2">
          Built by
        </p>
        <p class="text-text">
          {SITE.author}
        </p>
        <p class="font-mono text-xs text-muted mt-1">
          Deployed on Cloudflare · {year} →
        </p>
      </div>

      <nav aria-label="Footer navigation">
        <p class="font-mono text-xs text-muted uppercase tracking-widest mb-3">Navigate</p>
        <ul class="flex flex-col gap-1.5">
          <li><a href="#hero" class="hover:text-lime">Top</a></li>
          <li><a href="#stack" class="hover:text-lime">Stack</a></li>
          <li><a href="#work" class="hover:text-lime">Work</a></li>
          <li><a href="#services" class="hover:text-lime">Services</a></li>
          <li><a href="#contact" class="hover:text-lime">Contact</a></li>
        </ul>
      </nav>

      <div>
        <p class="font-mono text-xs text-muted uppercase tracking-widest mb-3">Elsewhere</p>
        <ul class="flex flex-col gap-1.5">
          {
            socialList.map((s) => (
              <li>
                <a
                  href={s.href}
                  target={s.href.startsWith('http') ? '_blank' : undefined}
                  rel={s.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                  class="hover:text-lime"
                >
                  {s.label} ↗
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</footer>
