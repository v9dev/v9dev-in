---
import HeroKinetic from './HeroKinetic.tsx';
import HeroSubtitle from './HeroSubtitle.tsx';
import HeroStatus from './HeroStatus.tsx';
import HeroAmbient from './HeroAmbient.tsx';
import MagneticButton from '@components/ui/MagneticButton.tsx';

const subtitle =
  "Forward Deployed Engineer - I ship cloud infra that doesn't fall over, and the products that run on top.";
---

<section
  id="hero"
  data-index="1"
  class="relative isolate min-h-[100svh] flex flex-col items-center justify-center overflow-hidden px-4 pt-28 pb-16"
>
  {/* Ambient gradient blobs - drift + pointer parallax */}
  <HeroAmbient client:load />


  {/* Live status */}
  <HeroStatus client:load />

  {/* Kinetic name */}
  <HeroKinetic client:load text="JP SINGH" />

  {/* Subtitle */}
  <div class="mt-10">
    <HeroSubtitle client:load text={subtitle} />
  </div>

  {/* CTAs */}
  <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
    <MagneticButton
      client:visible
      href="#work"
      strength={0.25}
      radius={80}
      className="rounded-full bg-text px-5 py-2.5 text-sm font-semibold text-canvas hover:bg-white"
      data-cursor-label="see work"
    >
      See work ↓
    </MagneticButton>
    <MagneticButton
      client:visible
      href="#contact"
      strength={0.25}
      radius={80}
      className="rounded-full border border-line/80 px-5 py-2.5 text-sm font-semibold text-text hover:border-lime hover:text-lime transition-colors"
      data-cursor-label="say hi"
    >
      Book a call →
    </MagneticButton>
  </div>

  {/* Scroll indicator */}
  <div
    aria-hidden
    class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-muted"
  >
    <span class="font-mono text-[10px] tracking-[0.3em] uppercase scroll-pulse">scroll</span>
    <span class="relative block h-10 w-px overflow-hidden bg-line/30">
      <span class="scroll-dot absolute left-1/2 -translate-x-1/2 -top-2 size-1 rounded-full bg-lime"></span>
    </span>
  </div>

  <style>
    @keyframes scroll-dot {
      0% { transform: translate(-50%, -200%); opacity: 0; }
      30% { opacity: 1; }
      100% { transform: translate(-50%, 320%); opacity: 0; }
    }
    .scroll-dot {
      animation: scroll-dot 2.4s cubic-bezier(0.65, 0, 0.35, 1) infinite;
    }
    @keyframes scroll-pulse-op {
      0%, 100% { opacity: 0.6; letter-spacing: 0.3em; }
      50%      { opacity: 1;   letter-spacing: 0.4em; }
    }
    .scroll-pulse {
      animation: scroll-pulse-op 3.6s ease-in-out infinite;
    }
    @media (prefers-reduced-motion: reduce) {
      .scroll-dot, .scroll-pulse { animation: none; }
    }
  </style>
</section>
