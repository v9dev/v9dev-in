---
/**
 * K8S - Kubernetes explained in the same solid 3D language as the
 * silicon board: real CSS 3D cuboids with per-face lighting on a dark
 * board plane, choreographed by anime.js in one looping control-loop
 * story - the cluster builds itself, kubectl apply lands, the scheduler
 * binds pods, a service balances traffic, a pod dies and is healed,
 * the deployment scales 3 → 5, then everything sinks and rebuilds.
 *
 * Same interactions as silicon: drag to orbit (auto-returns to a
 * living wobble), plus a tick-strip timeline you can drag to scrub the
 * whole story. Pauses offscreen; static under prefers-reduced-motion;
 * zero React runtime.
 */

interface Part {
  id: string;
  cls: string;
  x: number;
  y: number;
  w: number; // footprint width (board x)
  d: number; // footprint depth (board y)
  h: number; // extrusion height (z)
  label?: string;
}

const NODE_YS = [90, 260, 430];

const PARTS: Part[] = [
  // control plane podium + components
  { id: 'cp-plat', cls: 'k-plat', x: 40, y: 120, w: 280, d: 360, h: 10 },
  { id: 'api', cls: 'k-box', x: 70, y: 150, w: 220, d: 70, h: 40, label: 'api-server' },
  { id: 'etcd', cls: 'k-box', x: 70, y: 260, w: 100, d: 90, h: 52, label: 'etcd' },
  { id: 'sched', cls: 'k-box', x: 200, y: 260, w: 90, d: 90, h: 36, label: 'sched' },
  { id: 'ctrl', cls: 'k-box', x: 70, y: 390, w: 220, d: 60, h: 30, label: 'ctrl-mgr' },
  // ingress
  { id: 'ingress', cls: 'k-box', x: 380, y: 16, w: 150, d: 60, h: 22, label: 'ingress' },
  // worker node plates + kubelets
  ...NODE_YS.flatMap((y, i) => [
    {
      id: `node-${i + 1}`,
      cls: 'k-node',
      x: 480,
      y,
      w: 400,
      d: 140,
      h: 14,
      label: `node-${i + 1}`,
    },
    {
      id: `kubelet-${i + 1}`,
      cls: 'k-box k-kubelet',
      x: 790,
      y: y + 18,
      w: 74,
      d: 38,
      h: 20,
      label: 'kubelet',
    },
  ]),
];

/** [id, nodeIndex, slot] - pods, spawned by the story. */
const PODS: Array<[string, number, number]> = [
  ['p11', 0, 0],
  ['p12', 0, 1],
  ['p21', 1, 0],
  ['p22', 1, 1],
  ['p31', 2, 0],
  ['p32', 2, 1],
];
const podX = (slot: number) => 505 + slot * 104;
const podY = (node: number) => NODE_YS[node] + 62;

/** Traces on the board plane: api-server spine + per-node lanes. [x,y,w,h] */
const TRACES: Array<[string, number, number, number, number]> = [
  ['t-stub', 290, 179, 110, 6],
  ['t-spine', 400, 160, 6, 346],
  ['t-lane1', 400, 157, 80, 6],
  ['t-lane2', 400, 327, 80, 6],
  ['t-lane3', 400, 497, 80, 6],
];

const CAPTIONS = [
  'building the cluster',
  'kubectl apply -f deploy.yaml',
  'scheduler binds 3 pods',
  'service balances traffic',
  'pod dies · control loop heals',
  'scale: replicas 3 → 5',
  'declared state == actual state',
  'tear down · loop',
];
---

<section id="k8s" aria-label="Animated 3D scene explaining how Kubernetes works: a cluster builds itself, schedules pods, balances traffic, self-heals and scales" class="relative py-[var(--section-pad)]">
  <div class="container-page">
    <div class="section-label text-cyan/80"><span>// orchestration</span></div>
    <div class="mt-3 flex flex-wrap items-end justify-between gap-4">
      <p class="max-w-md font-display text-2xl md:text-3xl font-semibold leading-tight text-balance">
        How Kubernetes <span class="text-cyan">actually works.</span>
      </p>
      <p class="max-w-xs font-mono text-[11px] uppercase tracking-widest leading-relaxed text-muted">
        one control loop · drag to rotate · scrub the strip
      </p>
    </div>
  </div>

  <div class="k8s-viewport" id="k8s-stage" aria-hidden="true">
    <div class="k8s-shadow"></div>
    <div class="k8s-scale">
      <div class="k8s-tilt" id="k8s-tilt">
        <div class="k8s-board">
          <div class="k8s-pcb"></div>

          {TRACES.map(([id, x, y, w, h]) => (
            <div
              class="k8s-trace"
              id={id}
              style={`left:${x}px; top:${y}px; width:${w}px; height:${h}px;`}
            >
            </div>
          ))}

          {PARTS.map((p) => (
            <div
              class={`k8s-cub ${p.cls}`}
              id={p.id}
              style={`left:${p.x}px; top:${p.y}px; width:${p.w}px; height:${p.d}px; --h:${p.h}px;`}
            >
              <div class="face f-top">
                {p.label && <span class="k8s-face-label">{p.label.toUpperCase()}</span>}
              </div>
              <div class="face f-s"></div>
              <div class="face f-e"></div>
              <div class="face f-n"></div>
              <div class="face f-w"></div>
            </div>
          ))}

          {PODS.map(([id, node, slot]) => (
            <div
              class="k8s-cub k8s-pod"
              id={id}
              style={`left:${podX(slot)}px; top:${podY(node)}px; width:84px; height:58px; --h:32px;`}
            >
              <div class="face f-top"><span class="k8s-face-label">POD</span></div>
              <div class="face f-s"></div>
              <div class="face f-e"></div>
              <div class="face f-n"></div>
              <div class="face f-w"></div>
              <div class="pod-glow"></div>
            </div>
          ))}

          {/* kubectl manifest - a glowing chip that flies to the api-server */}
          <div class="k8s-manifest" id="k8s-manifest"></div>

          {/* traffic packets */}
          <div class="k8s-pkt" id="kdot-a"></div>
          <div class="k8s-pkt" id="kdot-b"></div>
          <div class="k8s-pkt" id="kdot-c"></div>
        </div>
      </div>
    </div>
  </div>

  {/* HUD: caption ticker + replicas + scrub strip */}
  <div class="container-page relative z-10 mt-2 flex flex-wrap items-center justify-between gap-4">
    <div class="flex items-center gap-3 font-mono text-[11px] uppercase tracking-[0.25em] text-muted">
      <span>phase:</span>
      <span class="k8s-cap-window">
        <span class="k8s-cap-list" id="k8s-captions">
          {CAPTIONS.map((c) => (
            <span class="k8s-cap text-cyan">{c}</span>
          ))}
        </span>
      </span>
      <span class="hidden sm:inline text-muted/70">· replicas: <span id="k8s-replicas" class="text-text">3</span></span>
    </div>
    <div
      id="k8s-scrub"
      role="slider"
      aria-label="Scrub the Kubernetes animation timeline"
      aria-valuemin="0"
      aria-valuemax="100"
      aria-valuenow="0"
      tabindex="0"
      data-cursor-label="scrub"
    >
      <div id="k8s-playhead"></div>
    </div>
  </div>
</section>

<style>
  /* Free 3D stage, silicon-style: absolute-centered, scale3d sized,
     spill allowed (html overflow-x clip guards the page edge). */
  .k8s-viewport {
    position: relative;
    height: clamp(26rem, 62vh, 40rem);
    perspective: 1400px;
    perspective-origin: 50% 30%;
    cursor: grab;
    touch-action: pan-y;
    user-select: none;
    -webkit-user-select: none;
  }
  .k8s-viewport.dragging {
    cursor: grabbing;
  }
  .k8s-viewport > * {
    pointer-events: none;
  }

  .k8s-shadow {
    position: absolute;
    left: 50%;
    top: 62%;
    width: 46rem;
    height: 11rem;
    transform: translate(-50%, -50%);
    background: radial-gradient(closest-side, rgb(0 0 0 / 0.55), transparent 70%);
    filter: blur(28px);
  }

  .k8s-scale,
  .k8s-tilt,
  .k8s-board,
  .k8s-cub {
    transform-style: preserve-3d;
  }

  .k8s-scale {
    --s: 0.38;
    position: absolute;
    left: 50%;
    top: 52%;
    width: 920px;
    height: 600px;
    transform: translate(-50%, -50%) scale3d(var(--s), var(--s), var(--s));
  }
  @media (min-width: 640px) {
    .k8s-scale {
      --s: 0.58;
    }
  }
  @media (min-width: 1024px) {
    .k8s-scale {
      --s: 0.76;
      top: 50%;
    }
  }
  @media (min-width: 1400px) {
    .k8s-scale {
      --s: 0.86;
    }
  }

  .k8s-tilt {
    position: absolute;
    inset: 0;
    /* Static pose - the script takes over for wobble + orbit. */
    transform: rotateX(56deg) rotateZ(-16deg);
    will-change: transform;
  }

  .k8s-board {
    position: relative;
    width: 920px;
    height: 600px;
  }

  .k8s-pcb {
    position: absolute;
    inset: 0;
    border-radius: 22px;
    border: 1px solid color-mix(in srgb, var(--color-line) 80%, transparent);
    background:
      radial-gradient(60rem 30rem at 70% 15%, rgb(58 224 255 / 0.05), transparent 55%),
      radial-gradient(50rem 26rem at 20% 85%, rgb(184 255 58 / 0.04), transparent 55%),
      repeating-linear-gradient(0deg, transparent 0 39px, rgb(42 42 54 / 0.5) 39px 40px),
      repeating-linear-gradient(90deg, transparent 0 39px, rgb(42 42 54 / 0.5) 39px 40px),
      linear-gradient(145deg, #0e1218, #0a0d12 60%, #0c0f15);
    box-shadow: inset 0 0 60px rgb(0 0 0 / 0.55);
  }
  .k8s-pcb::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 22px;
    background: #05070a;
    transform: translateZ(-14px);
  }

  .k8s-trace {
    position: absolute;
    border-radius: 3px;
    background: color-mix(in srgb, var(--color-cyan) 45%, transparent);
    opacity: 0.3;
    transform: translateZ(1px);
  }

  /* ── cuboids - same face system + lighting as the silicon board ── */
  .k8s-cub {
    position: absolute;
  }
  .face {
    position: absolute;
    backface-visibility: hidden;
  }
  .f-top {
    inset: 0;
    transform: translateZ(var(--h));
    background: linear-gradient(135deg, #232937, #161b26 65%);
    border: 1px solid rgb(255 255 255 / 0.07);
    border-radius: 6px;
    display: grid;
    place-items: center;
  }
  .f-s {
    left: 0;
    right: 0;
    bottom: 0;
    height: var(--h);
    transform-origin: bottom;
    transform: rotateX(-90deg);
    background: linear-gradient(180deg, #1b2130, #10141d);
  }
  .f-n {
    left: 0;
    right: 0;
    top: 0;
    height: var(--h);
    transform-origin: top;
    transform: rotateX(90deg);
    background: #0d1119;
  }
  .f-e {
    top: 0;
    bottom: 0;
    right: 0;
    width: var(--h);
    transform-origin: right;
    transform: rotateY(90deg);
    background: linear-gradient(90deg, #171c28, #10141d);
  }
  .f-w {
    top: 0;
    bottom: 0;
    left: 0;
    width: var(--h);
    transform-origin: left;
    transform: rotateY(-90deg);
    background: #0c0f16;
  }

  .k8s-face-label {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.28em;
    color: color-mix(in srgb, var(--color-muted) 85%, transparent);
    pointer-events: none;
  }
  .k-kubelet .k8s-face-label {
    font-size: 9px;
    letter-spacing: 0.18em;
  }
  .k8s-pod .k8s-face-label {
    font-size: 10px;
    letter-spacing: 0.22em;
  }

  /* platforms + node plates: flatter, darker tops */
  .k-plat .f-top {
    background: linear-gradient(145deg, #141924, #0e1219 70%);
    border-radius: 14px;
  }
  .k-node .f-top {
    background: linear-gradient(150deg, #171d29, #101521 70%);
    border-radius: 12px;
  }
  .k-node .k8s-face-label {
    position: absolute;
    left: 18px;
    top: 12px;
  }
  .k-kubelet .f-top {
    background: linear-gradient(150deg, #262c3a, #141924);
  }

  /* pods glow lime when healthy */
  .k8s-pod .f-top {
    border-color: rgb(184 255 58 / 0.35);
  }
  .pod-glow {
    position: absolute;
    inset: -3px;
    border-radius: 8px;
    background: var(--color-lime);
    filter: blur(10px);
    opacity: 0;
    transform: translateZ(2px);
  }

  .k8s-manifest {
    position: absolute;
    left: 0;
    top: 0;
    width: 26px;
    height: 34px;
    border-radius: 5px;
    border: 1.5px solid var(--color-lime);
    background: rgb(184 255 58 / 0.12);
    box-shadow: 0 0 14px rgb(184 255 58 / 0.6);
    opacity: 0;
  }

  .k8s-pkt {
    position: absolute;
    left: 0;
    top: 0;
    width: 14px;
    height: 14px;
    border-radius: 4px;
    background: var(--color-cyan);
    box-shadow:
      0 0 10px var(--color-cyan),
      0 0 26px color-mix(in srgb, var(--color-cyan) 55%, transparent);
    opacity: 0;
  }

  /* caption ticker */
  .k8s-cap-window {
    display: inline-block;
    height: 16px;
    overflow: hidden;
    vertical-align: bottom;
  }
  .k8s-cap-list {
    display: flex;
    flex-direction: column;
  }
  .k8s-cap {
    height: 16px;
    line-height: 16px;
    white-space: nowrap;
  }

  /* scrub strip - tick bar with a playhead */
  #k8s-scrub {
    position: relative;
    width: min(20rem, 60vw);
    height: 34px;
    border-radius: 8px;
    background:
      repeating-linear-gradient(
        90deg,
        rgb(245 245 240 / 0.22) 0 1.5px,
        transparent 1.5px 7px
      ),
      #101018;
    border: 1px solid var(--color-line);
    cursor: ew-resize;
    touch-action: none;
    overflow: hidden;
  }
  #k8s-scrub:focus-visible {
    outline: 2px solid var(--color-lime);
    outline-offset: 3px;
  }
  #k8s-playhead {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 3px;
    background: var(--color-fuchsia);
    box-shadow: 0 0 8px var(--color-fuchsia);
  }
</style>

<script>
  import { animate, createTimeline, stagger, utils } from 'animejs';

  const section = document.getElementById('k8s');
  const stage = document.getElementById('k8s-stage');
  const tilt = document.getElementById('k8s-tilt');
  const scrub = document.getElementById('k8s-scrub');
  const playhead = document.getElementById('k8s-playhead');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (section && stage && tilt && scrub && playhead && !reduced) {
    const LIME = '#b8ff3a';
    const FUCHSIA = '#ff3a8c';
    const CYAN = '#3ae0ff';
    const NODE_YS = [90, 260, 430];
    const podCenter = (slot: number, node: number) => ({
      x: 505 + slot * 104 + 42,
      y: NODE_YS[node] + 62 + 29,
    });

    const BUILD = ['#cp-plat', '#node-1', '#node-2', '#node-3', '#api', '#etcd', '#sched', '#ctrl', '#kubelet-1', '#kubelet-2', '#kubelet-3', '#ingress'];
    const INIT_PODS = ['#p11', '#p21', '#p31'];
    const LATE_PODS = ['#p32', '#p12', '#p22'];

    // Blank slate - everything hovering invisible above its spot.
    utils.set(BUILD.join(','), { z: 140, opacity: 0 });
    utils.set([...INIT_PODS, ...LATE_PODS].join(','), { z: 60, opacity: 0, scale: 0.6 });
    utils.set('.k8s-trace', { opacity: 0 });
    utils.set('#k8s-manifest', { x: 330, y: -70, z: 60, opacity: 0 });
    utils.set('.k8s-pkt', { z: 20 });

    const capEl = '#k8s-captions';

    const tl = createTimeline({
      loop: true,
      defaults: { ease: 'inOutQuad' },
      onUpdate: (self) => {
        const p = self.iterationDuration ? self.iterationCurrentTime / self.iterationDuration : 0;
        playhead.style.left = `${Math.min(99, p * 100)}%`;
        scrub.setAttribute('aria-valuenow', String(Math.round(p * 100)));
      },
    });

    const cap = (idx: number, atMs: number) => {
      tl.add(capEl, { y: -16 * idx, duration: 260, ease: 'outExpo' }, atMs);
    };

    /** Flash a component's top face in an accent color. */
    const glow = (id: string, hex: string, atMs: number, dur = 700) => {
      tl.add(`${id} .f-top`, {
        borderColor: [
          { to: hex, duration: 180, ease: 'outQuad' },
          { to: 'rgba(255, 255, 255, 0.07)', duration: dur },
        ],
        boxShadow: [
          { to: `0 0 22px ${hex}`, duration: 180, ease: 'outQuad' },
          { to: '0 0 0px rgba(0,0,0,0)', duration: dur },
        ],
      }, atMs);
    };

    /** A pod rises out of its node plate and lights up. */
    const spawnPod = (id: string, atMs: number) => {
      tl.add(id, {
        z: { from: 60, to: 0, duration: 550 },
        opacity: { from: 0, to: 1, duration: 300 },
        scale: { from: 0.6, to: 1, duration: 550 },
        ease: 'outBack(1.4)',
      }, atMs);
      tl.add(`${id} .pod-glow`, {
        opacity: [{ from: 0, to: 0.75, duration: 220 }, { to: 0.18, duration: 500 }],
      }, atMs + 380);
    };

    /** One traffic packet: ingress → down the aisle → into a pod. */
    const shoot = (dot: string, slot: number, node: number, atMs: number) => {
      const c = podCenter(slot, node);
      tl.add(dot, {
        x: { from: 448, to: 448, duration: 90 },
        y: { from: 82, to: 82, duration: 90 },
        opacity: { from: 0, to: 1, duration: 90 },
      }, atMs);
      tl.add(dot, { y: { to: c.y }, duration: 380, ease: 'inOutQuad' }, atMs + 100);
      tl.add(dot, { x: { to: c.x - 7 }, duration: 300, ease: 'outQuad' }, atMs + 480);
      tl.add(dot, { opacity: 0, duration: 90 }, atMs + 790);
    };

    // ── phase 1 · the cluster builds itself ───────────────────────
    cap(0, 0);
    tl.add(BUILD.join(','), {
      z: { from: 140, to: 0, duration: 750 },
      opacity: { from: 0, to: 1, duration: 400 },
      ease: 'outCubic',
      delay: stagger(130),
    }, 100);
    tl.add('.k8s-trace', { opacity: { from: 0, to: 0.3, duration: 500 }, delay: stagger(90) }, 1700);

    // ── phase 2 · kubectl apply ───────────────────────────────────
    cap(1, 2800);
    tl.add('#k8s-manifest', {
      opacity: [{ from: 0, to: 1, duration: 180 }, { to: 1, duration: 500 }, { to: 0, duration: 200 }],
      x: { from: 330, to: 170, duration: 880 },
      y: { from: -70, to: 165, duration: 880 },
      z: { from: 60, to: 42, duration: 880 },
    }, 2800);
    glow('#api', LIME, 3700);
    glow('#etcd', LIME, 3950, 900);

    // ── phase 3 · scheduler binds pods ────────────────────────────
    cap(2, 4600);
    glow('#sched', CYAN, 4600, 500);
    tl.add('.k8s-trace', {
      opacity: [{ to: 0.85, duration: 220, ease: 'outQuad' }, { to: 0.3, duration: 600 }],
      delay: stagger(70),
    }, 4800);
    spawnPod('#p11', 5100);
    spawnPod('#p21', 5350);
    spawnPod('#p31', 5600);

    // ── phase 4 · service balances traffic ────────────────────────
    cap(3, 7000);
    glow('#ingress', CYAN, 7000, 500);
    shoot('#kdot-a', 0, 0, 7050);
    shoot('#kdot-b', 0, 1, 7400);
    shoot('#kdot-c', 0, 2, 7750);
    shoot('#kdot-a', 0, 0, 8100);

    // ── phase 5 · a pod dies, the control loop heals ──────────────
    cap(4, 9000);
    tl.add('#p21 .f-top', {
      borderColor: [
        { to: FUCHSIA, duration: 130 },
        // legacy comma syntax - anime's color parser rejects rgb(r g b / a)
        { to: 'rgba(184, 255, 58, 0.35)', duration: 130 },
        { to: FUCHSIA, duration: 130 },
      ],
    }, 9000);
    tl.add('#p21 .pod-glow', { backgroundColor: FUCHSIA, opacity: 0.6, duration: 250 }, 9200);
    tl.add('#p21', {
      z: { to: -26, duration: 600, ease: 'inQuad' },
      opacity: { to: 0, duration: 600 },
      scale: { to: 0.55, duration: 600 },
    }, 9500);
    glow('#ctrl', FUCHSIA, 9700, 600);
    glow('#api', CYAN, 10100, 500);
    spawnPod('#p32', 10600);

    // ── phase 6 · scale 3 → 5 ─────────────────────────────────────
    cap(5, 11800);
    tl.call(() => {
      const r = document.getElementById('k8s-replicas');
      if (r) r.textContent = '5';
    }, 11900);
    glow('#api', LIME, 11900, 500);
    spawnPod('#p12', 12100);
    spawnPod('#p22', 12400);
    shoot('#kdot-b', 1, 0, 13100);
    shoot('#kdot-c', 1, 2, 13450);

    // ── phase 7 · steady state ────────────────────────────────────
    cap(6, 14300);
    tl.add('.k8s-pod .pod-glow', {
      opacity: [{ to: 0.55, duration: 280 }, { to: 0.18, duration: 380 }],
      delay: stagger(100),
    }, 14400);

    // ── phase 8 · tear down and loop ──────────────────────────────
    cap(7, 15500);
    tl.call(() => {
      const r = document.getElementById('k8s-replicas');
      if (r) r.textContent = '3';
    }, 15600);
    tl.add('#p21 .pod-glow', { backgroundColor: LIME, opacity: 0, duration: 200 }, 15550);
    tl.add('.k8s-trace', { opacity: 0, duration: 350 }, 15600);
    tl.add('.k8s-pod', {
      z: { to: 60, duration: 450, ease: 'inCubic' },
      opacity: { to: 0, duration: 350 },
      delay: stagger(40),
    }, 15650);
    tl.add(BUILD.join(','), {
      z: { to: 140, duration: 550, ease: 'inCubic' },
      opacity: { to: 0, duration: 400 },
      delay: stagger(28, { from: 'last' }),
    }, 15850);
    tl.add(capEl, { y: 0, duration: 260, ease: 'outExpo' }, 16700);

    // ── silicon-style orbit: wobble + drag, auto-return ───────────
    const BASE_RX = 56;
    const BASE_RZ = -16;
    const POSE = { rx: BASE_RX, rz: BASE_RZ };
    utils.set(tilt, { rotateX: BASE_RX, rotateZ: BASE_RZ });

    const mkWobble = () =>
      animate(tilt, {
        rotateX: [
          { to: BASE_RX + 2, duration: 2800 },
          { to: BASE_RX - 2.5, duration: 4200 },
          { to: BASE_RX, duration: 2400 },
        ],
        rotateZ: [
          { to: BASE_RZ + 3, duration: 3400 },
          { to: BASE_RZ - 3, duration: 3600 },
          { to: BASE_RZ, duration: 2400 },
        ],
        ease: 'inOutSine',
        loop: true,
      });
    let wobble = mkWobble();

    let dragging = false;
    let returnAnim: ReturnType<typeof animate> | null = null;
    let idleTimer: ReturnType<typeof setTimeout> | undefined;

    stage.addEventListener('pointerdown', (e) => {
      dragging = true;
      stage.classList.add('dragging');
      stage.setPointerCapture(e.pointerId);
      wobble.pause();
      returnAnim?.pause();
      clearTimeout(idleTimer);
      POSE.rx = Number(utils.get(tilt, 'rotateX', false));
      POSE.rz = Number(utils.get(tilt, 'rotateZ', false));
    });
    stage.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      POSE.rz = utils.clamp(POSE.rz + e.movementX * 0.2, -78, 44);
      POSE.rx = utils.clamp(POSE.rx - e.movementY * 0.18, 34, 72);
      utils.set(tilt, { rotateX: POSE.rx, rotateZ: POSE.rz });
    });
    const endOrbit = () => {
      if (!dragging) return;
      dragging = false;
      stage.classList.remove('dragging');
      clearTimeout(idleTimer);
      idleTimer = setTimeout(() => {
        returnAnim = animate(tilt, {
          rotateX: BASE_RX,
          rotateZ: BASE_RZ,
          duration: 1400,
          ease: 'inOutQuad',
          onComplete: () => {
            wobble = mkWobble();
          },
        });
      }, 5000);
    };
    stage.addEventListener('pointerup', endOrbit);
    stage.addEventListener('pointercancel', endOrbit);

    // ── scrub strip: drag or click to seek ────────────────────────
    let scrubbing = false;
    const seek = (clientX: number) => {
      const r = scrub.getBoundingClientRect();
      const p = utils.clamp((clientX - r.left) / r.width, 0, 0.999);
      tl.currentTime = p * tl.iterationDuration;
    };
    scrub.addEventListener('pointerdown', (e) => {
      scrubbing = true;
      scrub.setPointerCapture(e.pointerId);
      tl.pause();
      seek(e.clientX);
    });
    scrub.addEventListener('pointermove', (e) => {
      if (scrubbing) seek(e.clientX);
    });
    const release = () => {
      if (!scrubbing) return;
      scrubbing = false;
      tl.play();
    };
    scrub.addEventListener('pointerup', release);
    scrub.addEventListener('pointercancel', release);
    scrub.addEventListener('keydown', (e) => {
      const step = tl.iterationDuration * 0.04;
      if (e.key === 'ArrowRight') {
        tl.currentTime = Math.min(tl.iterationDuration - 1, tl.iterationCurrentTime + step);
      } else if (e.key === 'ArrowLeft') {
        tl.currentTime = Math.max(0, tl.iterationCurrentTime - step);
      }
    });

    // ── run only while on screen ──────────────────────────────────
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting && !scrubbing) tl.play();
          else tl.pause();
        }
      },
      { threshold: 0.15 },
    );
    io.observe(section);
  }
</script>
