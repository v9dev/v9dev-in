---
// Notes is intentionally a single creative line for now - no posts.
// When JP wants a real blog, restore a post list here.
---

<section
  id="blog"
  data-index="6"
  class="relative overflow-hidden py-[var(--section-pad)]"
>
  <div aria-hidden class="absolute inset-0 -z-10">
    <div
      class="absolute top-1/2 -translate-y-1/2 right-0 size-[34rem] rounded-full blur-3xl opacity-[0.06]"
      style="background: radial-gradient(closest-side, var(--color-cyan), transparent 70%)"
    >
    </div>
  </div>

  <div class="container-page text-center">
    <div class="section-label justify-center mb-8 text-cyan/80">
      <span>06 · Notes</span>
    </div>

    <p
      class="font-display font-medium text-balance leading-[1.1] text-[clamp(1.75rem,5vw,4rem)] max-w-[22ch] mx-auto"
    >
      No blog yet. If you'd actually
      <span class="text-cyan">read it</span>, I'll
      <span class="text-cyan">write it</span>.
    </p>

    <a
      href="#contact"
      class="link-underline mt-8 inline-block font-mono text-xs uppercase tracking-widest text-muted"
      data-cursor-label="tell me"
    >
      Tell me what to write ↘
    </a>
  </div>
</section>
