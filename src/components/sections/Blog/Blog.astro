---
import { posts } from '@content/posts';

const fmt = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});
---

<section
  id="blog"
  data-index="6"
  class="relative overflow-hidden py-[var(--section-pad)]"
>
  <div aria-hidden class="absolute inset-0 -z-10">
    <div
      class="absolute -top-32 right-0 size-[36rem] rounded-full blur-3xl opacity-[0.06]"
      style="background: radial-gradient(closest-side, var(--color-cyan), transparent 70%)"
    >
    </div>
  </div>

  <div class="container-page">
    <div class="flex items-end justify-between gap-6 mb-12 flex-wrap">
      <div>
        <div class="section-label mb-4 text-cyan/80">
          <span>06 · Notes</span>
        </div>
        <h2 class="font-display font-semibold text-balance leading-[0.95] text-[clamp(2.25rem,5.5vw,4.5rem)] max-w-3xl">
          Things I write
          <br />
          <span class="text-cyan">while I build.</span>
        </h2>
      </div>
      <p class="font-mono text-xs text-muted max-w-xs leading-relaxed">
        Short field notes on infra, self-hosting, and quietly cutting cloud bills.
      </p>
    </div>

    <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
      {
        posts.map((p) => (
          <li>
            <a
              href={p.href ?? `/blog/${p.slug}`}
              class="group block h-full rounded-3xl border border-line/80 bg-elevated/60 p-5 sm:p-6 transition-colors hover:border-cyan/60 focus:outline-none focus-visible:ring-2 focus-visible:ring-cyan"
              data-cursor-label="read"
            >
              <div class="flex items-center justify-between text-[10px] font-mono uppercase tracking-widest text-muted mb-4">
                <span>{fmt.format(new Date(p.date))}</span>
                <span>{p.readMins} min read</span>
              </div>
              <h3 class="font-display text-lg sm:text-xl md:text-2xl font-semibold leading-tight text-balance group-hover:text-cyan transition-colors">
                {p.title}
              </h3>
              <p class="mt-3 text-muted leading-relaxed text-sm sm:text-[0.95rem]">
                {p.excerpt}
              </p>
              <div class="mt-5 flex flex-wrap items-center gap-2">
                {p.tags.map((t) => (
                  <span class="rounded-full bg-canvas/70 border border-line/60 px-2 py-0.5 font-mono text-[10px] uppercase tracking-wider text-text/80">
                    {t}
                  </span>
                ))}
                <span class="ml-auto font-mono text-[10px] uppercase tracking-widest text-muted group-hover:text-cyan transition-colors">
                  Read ↗
                </span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>

    <p class="mt-10 text-center font-mono text-xs text-muted">
      Real posts coming soon - this is the shape; content lands in <code>src/content/posts.ts</code>.
    </p>
  </div>
</section>
