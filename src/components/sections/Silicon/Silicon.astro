---
/**
 * SILICON - an ambient, self-running 3D scene of what a request looks
 * like at the hardware level. Real CSS 3D geometry (perspective +
 * preserve-3d cuboids with per-face lighting), choreographed by anime.js.
 *
 * One grand loop, forever:
 *   1. machine cycle - a packet rides NIC → CPU, the die ripples,
 *      round trips hit RAM/NVMe, the answer rides home (pipeline ticker
 *      steps FETCH → WRITE-BACK)
 *   2. teardown - the camera zooms into the CPU, the heat spreader
 *      lifts off, the die rises, and an SVG lesson counts 0000 → 1010
 *      in binary with carry pulses (1010 = 8 + 2 = 10)
 *
 * Controls: drag to orbit the board, +/- to zoom, reset to recenter.
 * The scene never NEEDS interaction - it returns to its idle wobble a
 * few seconds after you let go. Pauses offscreen; static under
 * prefers-reduced-motion; zero React runtime.
 */

interface Part {
  id: string;
  x: number;
  y: number;
  w: number; // footprint width (board x)
  d: number; // footprint depth (board y)
  h: number; // extrusion height (z)
}

const CPU: Part = { id: 'cpu', x: 340, y: 190, w: 240, d: 240, h: 34 };
const DIMMS: Part[] = [
  { id: 'dimm-a', x: 656, y: 180, w: 16, d: 250, h: 52 },
  { id: 'dimm-b', x: 700, y: 180, w: 16, d: 250, h: 52 },
];
const NIC: Part = { id: 'nic', x: 100, y: 430, w: 130, d: 110, h: 22 };
const NVME: Part = { id: 'nvme', x: 600, y: 460, w: 190, d: 80, h: 14 };
const IO: Part = { id: 'io', x: 300, y: 570, w: 320, d: 18, h: 10 };
const CAPS: Part[] = [0, 1, 2, 3, 4].map((i) => ({
  id: `cap-${i}`,
  x: 268,
  y: 210 + i * 52,
  w: 26,
  d: 26,
  h: 30,
}));

const PARTS: Part[] = [CPU, ...DIMMS, NIC, NVME, IO, ...CAPS];

/** Copper traces on the board plane. [x, y, w, h, lane] */
const TRACES: Array<[number, number, number, number, string]> = [
  [160, 310, 6, 122, 'in'], // nic ↑ toward cpu row
  [160, 306, 182, 6, 'in'], // → into cpu west edge
  [580, 306, 78, 6, 'mem'], // cpu east edge → dimms
  [455, 430, 6, 66, 'store'], // cpu south edge ↓
  [455, 490, 148, 6, 'store'], // → toward nvme
];

const STAGES = ['fetch', 'decode', 'execute', 'memory', 'write-back', 'teardown', 'binary'];

const SPECS = [
  { label: 'cpu · 16-core die', color: 'var(--color-lime)' },
  { label: 'ddr5 · 2× dimm', color: 'var(--color-cyan)' },
  { label: 'nvme · gen4 ×4', color: 'var(--color-fuchsia)' },
  { label: 'nic · packets in/out', color: 'var(--color-amber)' },
];

/** Binary lesson cells, MSB → LSB with their place values. */
const BITS = [
  { bit: 3, weight: 8 },
  { bit: 2, weight: 4 },
  { bit: 1, weight: 2 },
  { bit: 0, weight: 1 },
];
---

<section id="silicon" aria-label="Animated 3D scene of a request travelling across computer hardware, with a CPU teardown showing binary counting" class="relative">
  <div class="container-page relative z-10 flex items-start justify-between gap-6 pt-10">
    <div>
      <div class="section-label text-lime/80"><span>// silicon</span></div>
      <p class="mt-3 max-w-md font-display text-2xl md:text-3xl font-semibold leading-tight text-balance">
        Every request ends <span class="text-lime">at the metal.</span>
      </p>
    </div>
    <div class="flex flex-col items-end gap-2 pt-1">
      <div class="flex gap-2">
        <button type="button" id="sil-zoom-out" aria-label="Zoom out" data-cursor-label="out"
          class="size-9 rounded-full border border-line/80 bg-elevated/70 backdrop-blur font-mono text-sm text-muted transition-colors hover:border-lime hover:text-lime focus:outline-none focus-visible:ring-2 focus-visible:ring-lime">−</button>
        <button type="button" id="sil-zoom-in" aria-label="Zoom in" data-cursor-label="in"
          class="size-9 rounded-full border border-line/80 bg-elevated/70 backdrop-blur font-mono text-sm text-muted transition-colors hover:border-lime hover:text-lime focus:outline-none focus-visible:ring-2 focus-visible:ring-lime">+</button>
        <button type="button" id="sil-reset" aria-label="Reset view" data-cursor-label="reset"
          class="size-9 rounded-full border border-line/80 bg-elevated/70 backdrop-blur font-mono text-sm text-muted transition-colors hover:border-lime hover:text-lime focus:outline-none focus-visible:ring-2 focus-visible:ring-lime">⟲</button>
      </div>
      <span class="hidden font-mono text-[10px] uppercase tracking-widest text-muted sm:block">drag to rotate</span>
    </div>
  </div>

  <div class="sil-viewport" id="sil-viewport" aria-hidden="true">
    <div class="sil-shadow"></div>
    <div class="sil-scale">
      <div class="sil-zoom-user">
        <div class="sil-zoom-act">
          <div class="sil-float">
            <div class="sil-board" id="sil-board">
              <div class="sil-pcb"></div>

              {TRACES.map(([x, y, w, h, lane]) => (
                <div
                  class="sil-trace"
                  data-trace={lane}
                  style={`left:${x}px; top:${y}px; width:${w}px; height:${h}px;`}
                >
                </div>
              ))}

              <div class="sil-heat" id="sil-heat"></div>

              {PARTS.map((p) => (
                <div
                  class={`sil-cub sil-${p.id.replace(/-\d$/, '').replace(/-[ab]$/, '')}`}
                  data-part={p.id}
                  style={`left:${p.x}px; top:${p.y}px; width:${p.w}px; height:${p.d}px; --h:${p.h}px;`}
                >
                  <div class="face f-top">
                    {p.id === 'nic' && <span class="sil-chip-label">NIC</span>}
                    {p.id === 'nvme' && <span class="sil-chip-label">NVME</span>}
                  </div>
                  <div class="face f-s"></div>
                  <div class="face f-e"></div>
                  <div class="face f-n"></div>
                  <div class="face f-w"></div>
                  {p.id === 'cpu' && (
                    <div class="sil-die-wrap" id="sil-die-wrap">
                      <div class="sil-die">
                        {Array.from({ length: 16 }).map(() => (
                          <div class="sil-core"></div>
                        ))}
                      </div>
                    </div>
                  )}
                  {p.id.startsWith('dimm') && <div class="sil-dimm-glow"></div>}
                </div>
              ))}

              {/* Binary lesson - hovers above the opened CPU during teardown */}
              <svg
                id="sil-binary"
                viewBox="0 0 260 220"
                width="260"
                height="220"
                style="left: 330px; top: 200px;"
              >
                <text x="130" y="22" text-anchor="middle" class="sil-b-title">inside the die · counting in binary</text>
                {BITS.map(({ bit, weight }, i) => {
                  const cx = 16 + i * 60;
                  return (
                    <g id={`bit-${bit}`}>
                      <text x={cx + 24} y="52" text-anchor="middle" class="sil-b-weight">{weight}</text>
                      <rect class="bt-cell" x={cx} y="62" width="48" height="58" rx="8" />
                      <text x={cx + 24} y="102" text-anchor="middle" class="bt-glyph bt-0">0</text>
                      <text x={cx + 24} y="102" text-anchor="middle" class="bt-glyph bt-1" opacity="0">1</text>
                      {bit < 3 && <circle id={`carry-${bit}`} cx={cx - 6} cy="91" r="5" class="sil-b-carry" opacity="0" />}
                    </g>
                  );
                })}
                <text x="130" y="158" text-anchor="middle" class="sil-b-dec" id="sil-b-dec">= 0</text>
                <text x="130" y="192" text-anchor="middle" class="sil-b-cap" id="sil-cap-a">each tick flips the 1s place · a full column carries left</text>
                <text x="130" y="192" text-anchor="middle" class="sil-b-cap sil-b-cap-final" id="sil-cap-b" opacity="0">1010 = 8 + 2 = 10</text>
              </svg>

              {/* Traveling packets - positioned by the script */}
              <div class="sil-pkt" id="pkt-in" style="--pk: var(--color-lime)"></div>
              <div class="sil-pkt" id="pkt-mem" style="--pk: var(--color-cyan)"></div>
              <div class="sil-pkt" id="pkt-store" style="--pk: var(--color-fuchsia)"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {/* HUD - flat overlay, not part of the 3D scene */}
  <div class="pointer-events-none absolute inset-x-0 bottom-6 z-10">
    <div class="container-page flex flex-wrap items-end justify-between gap-4">
      <div class="flex items-center gap-3 font-mono text-[11px] uppercase tracking-[0.25em] text-muted">
        <span>pipeline:</span>
        <span class="sil-stage-window">
          <span class="sil-stage-list" id="sil-stages">
            {STAGES.map((s) => (
              <span class="sil-stage text-lime">{s}</span>
            ))}
          </span>
        </span>
      </div>
      <ul class="hidden gap-x-6 gap-y-1.5 sm:flex sm:flex-wrap">
        {SPECS.map((s) => (
          <li class="flex items-center gap-2 font-mono text-[10px] uppercase tracking-widest text-muted">
            <span
              class="inline-block size-1.5 rounded-full"
              style={`background:${s.color}; box-shadow:0 0 8px ${s.color}`}
            >
            </span>
            {s.label}
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  /* No overflow clipping - the board may spill past the section while
     zoomed, rotated, or torn down. body{overflow-x:hidden} guards the
     page edge, and the whole 3D subtree is pointer-transparent so spill
     never blocks content around it. */
  #silicon {
    height: clamp(32rem, 84vh, 52rem);
  }

  .sil-viewport {
    position: absolute;
    inset: 0;
    perspective: 1400px;
    perspective-origin: 50% 30%;
    cursor: grab;
    touch-action: pan-y;
  }
  /* Drag is handled by the viewport itself; the scene never eats
     clicks - neither inside the section nor where it spills out. */
  .sil-viewport > * {
    pointer-events: none;
  }
  .sil-viewport.dragging {
    cursor: grabbing;
  }

  /* Soft ground shadow behind the whole scene */
  .sil-shadow {
    position: absolute;
    left: 50%;
    top: 62%;
    width: 46rem;
    height: 11rem;
    transform: translate(-50%, -50%);
    background: radial-gradient(closest-side, rgb(0 0 0 / 0.55), transparent 70%);
    filter: blur(28px);
  }

  .sil-scale,
  .sil-zoom-user,
  .sil-zoom-act,
  .sil-float,
  .sil-board,
  .sil-cub,
  .sil-die-wrap {
    transform-style: preserve-3d;
  }

  /* Absolutely centered: grid/flex centering start-aligns items that
     overflow the container (the mobile case). scale3d keeps z in
     proportion - a 2D scale() would leave z at full size and wildly
     exaggerate the perspective at small sizes. */
  .sil-scale {
    --s: 0.4;
    position: absolute;
    left: 50%;
    top: 53%;
    width: 920px;
    height: 600px;
    transform: translate(-50%, -50%) scale3d(var(--s), var(--s), var(--s));
  }
  @media (min-width: 640px) {
    .sil-scale {
      --s: 0.62;
    }
  }
  @media (min-width: 1024px) {
    .sil-scale {
      --s: 0.82;
      top: 50%;
    }
  }
  @media (min-width: 1400px) {
    .sil-scale {
      --s: 0.92;
    }
  }

  .sil-zoom-user,
  .sil-zoom-act {
    position: absolute;
    inset: 0;
  }

  .sil-board {
    position: relative;
    width: 920px;
    height: 600px;
    /* Static pose - the script takes over for the living wobble. */
    transform: rotateX(58deg) rotateZ(-18deg);
  }

  .sil-pcb {
    position: absolute;
    inset: 0;
    border-radius: 22px;
    border: 1px solid color-mix(in srgb, var(--color-line) 80%, transparent);
    background:
      radial-gradient(60rem 30rem at 30% 20%, rgb(184 255 58 / 0.045), transparent 55%),
      radial-gradient(50rem 26rem at 80% 80%, rgb(58 224 255 / 0.04), transparent 55%),
      repeating-linear-gradient(0deg, transparent 0 39px, rgb(42 42 54 / 0.5) 39px 40px),
      repeating-linear-gradient(90deg, transparent 0 39px, rgb(42 42 54 / 0.5) 39px 40px),
      linear-gradient(145deg, #0e1218, #0a0d12 60%, #0c0f15);
    box-shadow: inset 0 0 60px rgb(0 0 0 / 0.55);
  }
  /* Board substrate thickness */
  .sil-pcb::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 22px;
    background: #05070a;
    transform: translateZ(-14px);
  }

  .sil-trace {
    position: absolute;
    border-radius: 3px;
    background: linear-gradient(90deg, color-mix(in srgb, var(--color-text) 30%, transparent), color-mix(in srgb, var(--color-text) 14%, transparent));
    opacity: 0.32;
    transform: translateZ(1px);
  }
  .sil-trace[data-trace='in'] {
    background: color-mix(in srgb, var(--color-lime) 55%, transparent);
  }
  .sil-trace[data-trace='mem'] {
    background: color-mix(in srgb, var(--color-cyan) 55%, transparent);
  }
  .sil-trace[data-trace='store'] {
    background: color-mix(in srgb, var(--color-fuchsia) 55%, transparent);
  }

  .sil-heat {
    position: absolute;
    left: 250px;
    top: 100px;
    width: 420px;
    height: 420px;
    border-radius: 9999px;
    background: radial-gradient(closest-side, rgb(184 255 58 / 0.24), transparent 70%);
    filter: blur(26px);
    opacity: 0;
    transform: translateZ(2px);
  }

  /* ── Cuboid faces - z-up extrusion with faked directional light ── */
  .sil-cub {
    position: absolute;
  }
  .face {
    position: absolute;
    backface-visibility: hidden;
  }
  .f-top {
    inset: 0;
    transform: translateZ(var(--h));
    background: linear-gradient(135deg, #232937, #161b26 65%);
    border: 1px solid rgb(255 255 255 / 0.07);
    border-radius: 6px;
  }
  .f-s {
    left: 0;
    right: 0;
    bottom: 0;
    height: var(--h);
    transform-origin: bottom;
    transform: rotateX(-90deg);
    background: linear-gradient(180deg, #1b2130, #10141d);
  }
  .f-n {
    left: 0;
    right: 0;
    top: 0;
    height: var(--h);
    transform-origin: top;
    transform: rotateX(90deg);
    background: #0d1119;
  }
  .f-e {
    top: 0;
    bottom: 0;
    right: 0;
    width: var(--h);
    transform-origin: right;
    transform: rotateY(90deg);
    background: linear-gradient(90deg, #171c28, #10141d);
  }
  .f-w {
    top: 0;
    bottom: 0;
    left: 0;
    width: var(--h);
    transform-origin: left;
    transform: rotateY(-90deg);
    background: #0c0f16;
  }

  /* CPU heat spreader (the lid that lifts off in the teardown) */
  .sil-cpu .f-top {
    background:
      linear-gradient(135deg, rgb(255 255 255 / 0.09), transparent 45%),
      linear-gradient(160deg, #2b3140, #1a1f2b 70%, #202634);
    border-radius: 10px;
    border-color: rgb(255 255 255 / 0.12);
  }
  /* The die sits just above the lid; during teardown they separate. */
  .sil-die-wrap {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    transform: translateZ(calc(var(--h) + 1px));
  }
  .sil-die {
    width: 160px;
    height: 160px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 7px;
    padding: 10px;
    background: #0b0e15;
    border: 1px solid rgb(184 255 58 / 0.25);
    border-radius: 8px;
  }
  .sil-core {
    border-radius: 4px;
    background: #1a2029;
    border: 1px solid rgb(255 255 255 / 0.05);
  }

  /* DIMMs - thin standing slabs with gold pin stripe */
  .sil-dimm .f-e,
  .sil-dimm .f-w {
    background:
      linear-gradient(0deg, rgb(201 162 39 / 0.5) 0 7px, transparent 7px),
      linear-gradient(90deg, #1c2230, #12161f);
  }
  .sil-dimm .f-top {
    background: linear-gradient(135deg, #2c3344, #1a1f2b);
    border-radius: 3px;
  }
  .sil-dimm-glow {
    position: absolute;
    inset: -2px;
    border-radius: 4px;
    background: var(--color-cyan);
    filter: blur(6px);
    opacity: 0;
  }

  .sil-nic .f-top {
    background: linear-gradient(150deg, #262c3a, #141924);
  }
  .sil-nvme .f-top {
    background: linear-gradient(150deg, #212733, #131722);
  }
  .sil-chip-label {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-family: var(--font-mono);
    font-size: 15px;
    letter-spacing: 0.35em;
    color: color-mix(in srgb, var(--color-muted) 80%, transparent);
  }

  .sil-cap .f-top {
    border-radius: 9999px;
    background: radial-gradient(circle at 35% 30%, #39404f, #191e29 70%);
  }
  .sil-cap .f-s,
  .sil-cap .f-n,
  .sil-cap .f-e,
  .sil-cap .f-w {
    background: #151a24;
  }

  .sil-io .f-top {
    background: linear-gradient(90deg, #1d2330 0 6%, #12161f 6% 94%, #1d2330 94%);
  }

  /* ── Binary lesson SVG - flat on the board, raised by the script ── */
  #sil-binary {
    position: absolute;
    opacity: 0;
    transform: translateZ(36px);
    overflow: visible;
  }
  .sil-b-title,
  .sil-b-cap {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    fill: var(--color-muted);
  }
  .sil-b-weight {
    font-family: var(--font-mono);
    font-size: 13px;
    fill: var(--color-muted);
  }
  .bt-cell {
    fill: rgb(11 14 21 / 0.92);
    stroke: var(--color-line);
    stroke-width: 1.5;
  }
  .bt-glyph {
    font-family: var(--font-mono);
    font-size: 34px;
    font-weight: 700;
    fill: var(--color-text);
  }
  .bt-1 {
    fill: var(--color-lime);
  }
  .sil-b-carry {
    fill: var(--color-amber);
    filter: drop-shadow(0 0 6px var(--color-amber));
  }
  .sil-b-dec {
    font-family: var(--font-mono);
    font-size: 22px;
    font-weight: 700;
    fill: var(--color-cyan);
  }
  .sil-b-cap-final {
    fill: var(--color-lime);
  }

  .sil-pkt {
    position: absolute;
    left: 0;
    top: 0;
    width: 14px;
    height: 14px;
    border-radius: 4px;
    background: var(--pk);
    box-shadow:
      0 0 10px var(--pk),
      0 0 26px color-mix(in srgb, var(--pk) 55%, transparent);
    opacity: 0;
  }

  /* Pipeline stage ticker */
  .sil-stage-window {
    display: inline-block;
    height: 16px;
    overflow: hidden;
    vertical-align: bottom;
  }
  .sil-stage-list {
    display: flex;
    flex-direction: column;
  }
  .sil-stage {
    height: 16px;
    line-height: 16px;
  }
</style>

<script>
  import { animate, createTimeline, stagger, utils } from 'animejs';

  const section = document.getElementById('silicon');
  const viewport = document.getElementById('sil-viewport');
  const board = document.getElementById('sil-board');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (section && viewport && board && !reduced) {
    const LIME = '#b8ff3a';
    const CORE_BASE = '#1a2029';
    const LINE = '#2a2a36';
    const POSE = { rx: 58, rz: -18 };

    const lid = '.sil-cpu .f-top';
    const dieWrap = '#sil-die-wrap';
    const binary = '#sil-binary';

    // The script owns these transforms from here on (values match the
    // CSS fallbacks, so a no-JS/reduced render looks the same).
    utils.set(board, { rotateX: POSE.rx, rotateZ: POSE.rz });
    utils.set(lid, { z: 34 });
    utils.set(dieWrap, { z: 35 });
    utils.set(binary, { z: 36, opacity: 0 });

    /** Position a packet at board coords (center of a 14px square). */
    const at = (x: number, y: number) => ({ x: x - 7, y: y - 7 });
    const pktIn = '#pkt-in';
    const pktMem = '#pkt-mem';
    const pktStore = '#pkt-store';
    utils.set(pktIn, { ...at(163, 480), z: 14 });
    utils.set(pktMem, { ...at(585, 309), z: 14 });
    utils.set(pktStore, { ...at(458, 436), z: 14 });

    // ── Ambient life: wobble that starts/ends at the base pose ─────
    const mkWobble = () =>
      animate(board, {
        rotateX: [
          { to: 60, duration: 2600 },
          { to: 56.5, duration: 4200 },
          { to: POSE.rx, duration: 2200 },
        ],
        rotateZ: [
          { to: -15.5, duration: 3200 },
          { to: -20.5, duration: 3600 },
          { to: POSE.rz, duration: 2200 },
        ],
        ease: 'inOutSine',
        loop: true,
      });
    let wobble = mkWobble();

    const bob = animate('.sil-float', {
      y: [-8, 8],
      duration: 6400,
      ease: 'inOutSine',
      alternate: true,
      loop: true,
    });
    const caps = animate('.sil-cap .f-top', {
      opacity: [{ to: 0.75, duration: 900 }, { to: 1, duration: 900 }],
      delay: stagger(320),
      ease: 'inOutSine',
      alternate: true,
      loop: true,
    });

    // ── Controls: drag to orbit, buttons to zoom, auto-return ──────
    let dragging = false;
    let returnAnim: ReturnType<typeof animate> | null = null;
    let idleTimer: ReturnType<typeof setTimeout> | undefined;
    let userZoom = 1;

    const returnToIdle = () => {
      returnAnim = animate(board, {
        rotateX: POSE.rx,
        rotateZ: POSE.rz,
        duration: 1400,
        ease: 'inOutQuad',
        onComplete: () => {
          wobble = mkWobble();
        },
      });
    };

    viewport.addEventListener('pointerdown', (e) => {
      dragging = true;
      viewport.classList.add('dragging');
      viewport.setPointerCapture(e.pointerId);
      wobble.pause();
      returnAnim?.pause();
      clearTimeout(idleTimer);
      POSE.rx = Number(utils.get(board, 'rotateX', false));
      POSE.rz = Number(utils.get(board, 'rotateZ', false));
    });
    viewport.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      POSE.rz = utils.clamp(POSE.rz + e.movementX * 0.22, -80, 44);
      POSE.rx = utils.clamp(POSE.rx - e.movementY * 0.18, 38, 74);
      utils.set(board, { rotateX: POSE.rx, rotateZ: POSE.rz });
    });
    const endDrag = () => {
      if (!dragging) return;
      dragging = false;
      viewport.classList.remove('dragging');
      clearTimeout(idleTimer);
      idleTimer = setTimeout(() => {
        POSE.rx = 58;
        POSE.rz = -18;
        returnToIdle();
      }, 5000);
    };
    viewport.addEventListener('pointerup', endDrag);
    viewport.addEventListener('pointercancel', endDrag);

    const applyZoom = () => {
      animate('.sil-zoom-user', { scale: userZoom, duration: 450, ease: 'outQuad' });
    };
    document.getElementById('sil-zoom-in')?.addEventListener('click', () => {
      userZoom = utils.clamp(userZoom * 1.25, 0.55, 2.1);
      applyZoom();
    });
    document.getElementById('sil-zoom-out')?.addEventListener('click', () => {
      userZoom = utils.clamp(userZoom / 1.25, 0.55, 2.1);
      applyZoom();
    });
    document.getElementById('sil-reset')?.addEventListener('click', () => {
      userZoom = 1;
      applyZoom();
      wobble.pause();
      returnAnim?.pause();
      clearTimeout(idleTimer);
      POSE.rx = 58;
      POSE.rz = -18;
      returnToIdle();
    });

    const flash = (lane: string, atMs: number, tl: ReturnType<typeof createTimeline>) => {
      tl.add(
        `[data-trace="${lane}"]`,
        {
          opacity: [
            { to: 0.95, duration: 220, ease: 'outQuad' },
            { to: 0.32, duration: 700, ease: 'inOutSine' },
          ],
        },
        atMs,
      );
    };

    // ── The grand loop: machine cycle, then CPU teardown + binary ──
    const tl = createTimeline({ loop: true, defaults: { ease: 'inOutSine' } });
    const stageEl = '#sil-stages';
    const stageAt = (idx: number, atMs: number) => {
      tl.add(stageEl, { y: -16 * idx, duration: 260, ease: 'outExpo' }, atMs);
    };

    // ACT 1 - the machine cycle -------------------------------------
    // FETCH - a packet arrives NIC → CPU
    stageAt(0, 0);
    flash('in', 60, tl);
    tl.add(pktIn, { opacity: [{ to: 1, duration: 140 }] }, 0);
    tl.add(pktIn, { ...at(163, 309), duration: 520, ease: 'inOutQuad' }, 120);
    tl.add(pktIn, { ...at(330, 309), duration: 430, ease: 'inQuad' }, 680);
    tl.add(pktIn, { opacity: 0, duration: 140 }, 1080);

    // DECODE
    stageAt(1, 1150);

    // EXECUTE - the die ripples twice, heat blooms
    stageAt(2, 1650);
    for (const t of [1650, 2350]) {
      tl.add(
        '.sil-core',
        {
          backgroundColor: [
            { to: LIME, duration: 190, ease: 'outQuad' },
            { to: CORE_BASE, duration: 460, ease: 'inOutSine' },
          ],
          scale: [
            { to: 1.18, duration: 190, ease: 'outQuad' },
            { to: 1, duration: 460 },
          ],
          delay: stagger(42, { grid: [4, 4], from: 'center' }),
        },
        t,
      );
    }
    tl.add(
      '#sil-heat',
      {
        opacity: [
          { to: 0.85, duration: 700, ease: 'outQuad' },
          { to: 0, duration: 1400, ease: 'inOutSine' },
        ],
      },
      1700,
    );

    // MEMORY - round trip to the DIMMs, DMA to NVMe
    stageAt(3, 3000);
    flash('mem', 3000, tl);
    tl.add(pktMem, { opacity: [{ to: 1, duration: 120 }] }, 3000);
    tl.add(pktMem, { ...at(650, 309), duration: 380, ease: 'inOutQuad' }, 3080);
    tl.add('.sil-dimm-glow', { opacity: [{ to: 0.8, duration: 180 }, { to: 0, duration: 520 }], delay: stagger(90) }, 3380);
    tl.add(pktMem, { ...at(585, 309), duration: 380, ease: 'inOutQuad' }, 3660);
    tl.add(pktMem, { opacity: 0, duration: 120 }, 4020);

    flash('store', 3350, tl);
    tl.add(pktStore, { opacity: [{ to: 1, duration: 120 }] }, 3350);
    tl.add(pktStore, { ...at(458, 494), duration: 300, ease: 'inOutQuad' }, 3430);
    tl.add(pktStore, { ...at(595, 494), duration: 380, ease: 'inOutQuad' }, 3740);
    tl.add(pktStore, { opacity: 0, duration: 140 }, 4120);

    // WRITE-BACK - the answer rides home CPU → NIC
    stageAt(4, 4450);
    flash('in', 4500, tl);
    tl.add(pktIn, { opacity: [{ to: 1, duration: 120 }] }, 4500);
    tl.add(pktIn, { ...at(163, 309), duration: 430, ease: 'outQuad' }, 4560);
    tl.add(pktIn, { ...at(163, 480), duration: 520, ease: 'inOutQuad' }, 5030);
    tl.add(pktIn, { opacity: 0, duration: 160 }, 5550);

    // ACT 2 - teardown: zoom in, lift the lid, raise the die --------
    stageAt(5, 6300);
    // Scale AND drop the camera target so the raised binary panel stays
    // clear of the fixed nav at the top of the viewport.
    tl.add('.sil-zoom-act', { scale: 1.9, y: 96, duration: 1100, ease: 'inOutQuad' }, 6400);
    tl.add(lid, { z: 150, x: -20, y: -14, opacity: 0.28, duration: 950, ease: 'inOutQuad' }, 6650);
    tl.add(dieWrap, { z: 92, duration: 950, ease: 'inOutQuad' }, 6800);

    // ACT 3 - binary: count 0000 → 1010 with carry pulses -----------
    stageAt(6, 7500);
    tl.add(binary, { z: 150, opacity: 1, duration: 650, ease: 'outQuad' }, 7450);

    const TICK = 380;
    const T0 = 8300;
    for (let n = 1; n <= 10; n++) {
      const pos = T0 + (n - 1) * TICK;
      for (let b = 0; b < 4; b++) {
        const was = (n - 1) >> b & 1;
        const is = n >> b & 1;
        if (was === is) continue;
        tl.add(`#bit-${b} .bt-1`, { opacity: is ? 1 : 0, duration: 150, ease: 'outQuad' }, pos);
        tl.add(`#bit-${b} .bt-0`, { opacity: is ? 0 : 1, duration: 150, ease: 'outQuad' }, pos);
        tl.add(`#bit-${b} .bt-cell`, { stroke: is ? LIME : LINE, duration: 220 }, pos);
        if (!is && b < 3) {
          // A full column empties and carries one to the left.
          tl.add(`#carry-${b}`, {
            x: { from: 0, to: -48, duration: 240, ease: 'inOutQuad' },
            opacity: [{ to: 1, duration: 70 }, { to: 0, duration: 170 }],
          }, pos);
        }
      }
      tl.call(() => {
        const dec = document.getElementById('sil-b-dec');
        if (dec) dec.textContent = `= ${n}`;
      }, pos + 90);
    }

    // Land on 1010 and read it: 8 + 2 = 10.
    const DONE = T0 + 10 * TICK;
    tl.add('#sil-cap-a', { opacity: 0, duration: 260 }, DONE + 150);
    tl.add('#sil-cap-b', { opacity: 1, duration: 320 }, DONE + 320);
    tl.add(
      '.sil-core',
      {
        backgroundColor: [
          { to: LIME, duration: 160, ease: 'outQuad' },
          { to: CORE_BASE, duration: 420 },
        ],
        delay: stagger(26),
      },
      DONE + 400,
    );

    // Reassemble and zoom back out for the next request -------------
    const OUT = DONE + 1900;
    tl.add(binary, { opacity: 0, z: 60, duration: 480, ease: 'inQuad' }, OUT);
    tl.add(dieWrap, { z: 35, duration: 700, ease: 'inOutQuad' }, OUT + 250);
    tl.add(lid, { z: 34, x: 0, y: 0, opacity: 1, duration: 800, ease: 'inOutQuad' }, OUT + 400);
    tl.add('.sil-zoom-act', { scale: 1, y: 0, duration: 950, ease: 'inOutQuad' }, OUT + 550);
    tl.call(() => {
      const dec = document.getElementById('sil-b-dec');
      if (dec) dec.textContent = '= 0';
    }, OUT + 500);
    // Reset the lesson glyphs for the next pass.
    tl.add('.bt-1', { opacity: 0, duration: 200 }, OUT + 500);
    tl.add('.bt-0', { opacity: 1, duration: 200 }, OUT + 500);
    tl.add('.bt-cell', { stroke: LINE, duration: 200 }, OUT + 500);
    tl.add('#sil-cap-b', { opacity: 0, duration: 200 }, OUT + 500);
    tl.add('#sil-cap-a', { opacity: 1, duration: 200 }, OUT + 700);
    tl.add(stageEl, { y: 0, duration: 260, ease: 'outExpo' }, OUT + 1500);

    // ── Economy: run only while the scene is on screen ─────────────
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          for (const a of [wobble, bob, caps, tl]) {
            if (entry.isIntersecting) a.play();
            else a.pause();
          }
        }
      },
      { threshold: 0.08 },
    );
    io.observe(section);
  }
</script>
