---
import { services } from '@content/services';
import ServiceCard from './ServiceCard.tsx';
---

<section id="services" data-index="4" class="relative overflow-clip">
  <div class="container-page pt-[var(--section-pad)] pb-12">
    <div class="font-mono text-[11px] tracking-[0.3em] uppercase text-muted mb-4 flex items-center gap-2">
      <span class="inline-block w-8 h-px bg-cyan"></span>
      <span>04 · Services</span>
    </div>
    <h2 class="font-display font-semibold text-balance leading-[0.95] text-[clamp(2.25rem,5.5vw,4.5rem)] max-w-3xl">
      What I actually <span class="text-cyan">do.</span>
    </h2>
    <p class="mt-4 max-w-xl text-muted font-mono text-sm">
      Four flavours of engagement. Mix-and-match in practice.
    </p>
  </div>

  <div class="relative">
    {
      services.map((s, i) => (
        <ServiceCard
          client:visible
          service={s}
          index={i}
          total={services.length}
        />
      ))
    }
  </div>

  <div class="container-page pb-[var(--section-pad)]"></div>
</section>
