{
  "name": "v9dev-in",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "description": "v9dev.in - JP Singh's portfolio site",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "pages:dev": "wrangler pages dev --port 8788 -- pnpm dev --host",
    "typecheck": "astro check",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "assets:seo": "node scripts/gen-seo-assets.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.2.0",
    "@astrojs/react": "^4.2.0",
    "@astrojs/sitemap": "^3.2.1",
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@radix-ui/react-dialog": "^1.1.15",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^5.2.0",
    "clsx": "^2.1.1",
    "gsap": "^3.13.0",
    "lenis": "^1.1.20",
    "lucide-react": "^1.16.0",
    "motion": "^12.0.0",
    "nanoid": "^5.0.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "simple-icons": "^16.19.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/workers-types": "^4.20250109.0",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "wrangler": "^3.99.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,astro,json,css}": ["biome check --write --no-errors-on-unmatched"]
  }
}
